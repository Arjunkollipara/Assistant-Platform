# File: .env.example
# Purpose: Canonical environment variable template across local development and Azure production.

############################
# APP / API CONFIGURATION  #
############################
# Runtime mode: local | dev | staging | prod
APP_ENV=local
APP_NAME=business-assistant-backend
APP_DEBUG=true
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

############################
# POSTGRES (STRUCTURED DB) #
############################
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=business_assistant
POSTGRES_USER=business_user
POSTGRES_PASSWORD=business_password

############################
# MONGODB (DOCUMENT STORE) #
############################
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=business_assistant_docs
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin_password
MONGO_INGESTION_COLLECTION=ingestion_chunks

############################
# REDIS / CELERY           #
############################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
CELERY_BROKER_URL=redis://:redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

############################
# QDRANT (VECTOR DATABASE) #
############################
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=business_documents
QDRANT_API_KEY=

############################
# OBJECT STORAGE (MINIO)   #
############################
# MinIO is used locally to mirror blob-storage integration patterns.
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_PROCESSED=processed-data
MINIO_BUCKET_MODELS=model-artifacts
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_ENDPOINT_URL=http://minio:9000

############################
# LAYER 1 INGESTION        #
############################
INGESTION_MAX_FILE_SIZE_MB=25
INGESTION_ALLOWED_EXTENSIONS=csv,pdf,docx
INGESTION_CHUNK_SIZE=1000
INGESTION_CHUNK_OVERLAP=150
INGESTION_MAX_CHUNKS=300

############################
# MLFLOW                   #
############################
MLFLOW_HOST=mlflow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://model-artifacts

############################
# LLM / RAG (LOCAL)        #
############################
# Default local provider for development; switch to azure_openai in production.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=768
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.2
MAX_CONTEXT_TOKENS=6000

############################
# AZURE OPENAI (PROD)      #
############################
# Azure AI Foundry deployment target (example: GPT-4o chat deployment).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_MODEL_NAME=gpt-4o

############################
# SECURITY / AUTH          #
############################
JWT_SECRET_KEY=replace_with_strong_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated origins for local frontend clients.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

############################
# FRONTEND                 #
############################
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_DEFAULT_CHAT_PROVIDER=ollama
VITE_AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

##################################
# AZURE INFRA / DEPLOYMENT       #
##################################
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=business-assistant-rg
AZURE_LOCATION=eastus
AZURE_CONTAINER_REGISTRY=businessassistantacr
AZURE_APP_SERVICE_PLAN=business-assistant-plan
AZURE_BACKEND_APP_NAME=business-assistant-backend-app
AZURE_FRONTEND_APP_NAME=business-assistant-frontend-app
AZURE_STORAGE_ACCOUNT=businessassistantstorage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_RAW=raw-data
AZURE_BLOB_CONTAINER_PROCESSED=processed-data
AZURE_BLOB_CONTAINER_MODELS=model-artifacts
AZURE_BLOB_ENDPOINT=
AZURE_OPENAI_RESOURCE_NAME=

############################
# CI/CD IMAGE TARGETS      #
############################
BACKEND_IMAGE_NAME=ghcr.io/your-org/business-assistant-backend
FRONTEND_IMAGE_NAME=ghcr.io/your-org/business-assistant-frontend
